<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chhal Tebghini?</title>
    <style>
        :root {
            --pink-light: #ffebf0;
            --pink-medium: #ffb7c5;
            --pink-dark: #ff4d6d;
            --white: #ffffff;
        }

        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: var(--pink-light);
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            overflow: hidden;
            text-align: center;
        }

        /* Floating Hearts Background */
        .heart {
            position: absolute;
            color: var(--pink-medium);
            font-size: 20px;
            user-select: none;
            z-index: 0;
            animation: float 6s linear infinite;
            opacity: 0.6;
        }

        @keyframes float {
            0% { transform: translateY(100vh) rotate(0deg); opacity: 1; }
            100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
        }

        .container {
            position: relative;
            z-index: 10;
            background: rgba(255, 255, 255, 0.8);
            padding: 40px;
            border-radius: 30px;
            box-shadow: 0 10px 30px rgba(255, 77, 109, 0.1);
            backdrop-filter: blur(5px);
            width: 90%;
            max-width: 400px;
        }

        .teddy-bear {
            font-size: 80px;
            margin-bottom: 20px;
            display: block;
            animation: sway 3s ease-in-out infinite;
        }

        @keyframes sway {
            0%, 100% { transform: rotate(-5deg); }
            50% { transform: rotate(5deg); }
        }

        h1 {
            color: var(--pink-dark);
            font-size: 2rem;
            margin-bottom: 30px;
        }

        .btn-group {
            display: flex;
            justify-content: center;
            gap: 20px;
            height: 50px;
            align-items: center;
        }

        .btn {
            padding: 12px 30px;
            border-radius: 50px;
            cursor: pointer;
            font-size: 1.1rem;
            font-weight: bold;
            transition: all 0.3s ease;
            border: none;
            outline: none;
            text-decoration: none;
            display: inline-block;
        }

        /* "Chwya" Button: Pink Gradient */
        #btn-chwya {
            background: linear-gradient(45deg, #ff758c 0%, #ff7eb3 100%);
            color: white;
            box-shadow: 0 4px 15px rgba(255, 117, 140, 0.4);
        }

        #btn-chwya:hover {
            transform: scale(1.05);
        }

        /* "Bezaf" Button: Outlined & Evasive */
        #btn-bezaf {
            background: transparent;
            border: 2px solid var(--pink-dark);
            color: var(--pink-dark);
            position: relative;
        }

        #message {
            margin-top: 25px;
            color: var(--pink-dark);
            font-weight: bold;
            min-height: 24px;
            font-size: 1.2rem;
            transition: opacity 0.3s;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="teddy-bear">🧸</div>
        <h1 id="question">chhal tebghini ?</h1>
        
        <div class="btn-group">
            <button class="btn" id="btn-chwya">chwya</button>
            <button class="btn" id="btn-bezaf">bezaf</button>
        </div>

        <div id="message"></div>
    </div>

    <script>
        // 1. Generate Floating Hearts
        function createHeart() {
            const heart = document.createElement('div');
            heart.classList.add('heart');
            heart.innerHTML = '❤️';
            heart.style.left = Math.random() * 100 + 'vw';
            heart.style.animationDuration = (Math.random() * 3 + 3) + 's';
            document.body.appendChild(heart);
            
            setTimeout(() => { heart.remove(); }, 6000);
        }
        setInterval(createHeart, 400);

        const chwyaBtn = document.getElementById('btn-chwya');
        const bezafBtn = document.getElementById('btn-bezaf');
        const message = document.getElementById('message');

        // 2. "Chwya" Interaction: Show Message
        chwyaBtn.addEventListener('click', () => {
            message.innerText = "raak suuur? 🤨";
            message.style.opacity = '1';
        });

        // 3. "Bezaf" Interaction: Move away on hover
        bezafBtn.addEventListener('mouseover', moveButton);
        bezafBtn.addEventListener('touchstart', moveButton); // For mobile

        function moveButton() {
            // Calculate random positions within the visible viewport
            const padding = 50;
            const x = Math.random() * (window.innerWidth - bezafBtn.offsetWidth - padding);
            const y = Math.random() * (window.innerHeight - bezafBtn.offsetHeight - padding);

            // Set fixed position to allow movement across screen
            bezafBtn.style.position = 'fixed';
            bezafBtn.style.left = x + 'px';
            bezafBtn.style.top = y + 'px';
            
            // Clear message if they try to go for Bezaf
            message.innerText = "";
        }
    </script>
</body>
</html>
